<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice</title>

    <link rel="stylesheet" href="/tw.css?v=20260405">

    <style>
        @page {
            size: A4;
            margin: 8mm 10mm 3mm 10mm;
            height:260mm;
        }

        body {
            line-height: 1.3;
            margin: 0;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        /* ================= GRID FIX (FINAL) ================= */
.invoice-table {
    border-collapse: separate;
    border-spacing: 0;
    width: 100%;
}

/* RESET */
.invoice-table th,
.invoice-table td {
    padding: 4px 4px;
    box-shadow: none;
    min-height: 28px;
    vertical-align: middle;
}

/* COLUMN WIDTHS */
.invoice-table th:nth-child(1),
.invoice-table td:nth-child(1) {
    width: 30%;
}

.invoice-table th:nth-child(2),
.invoice-table td:nth-child(2) {
    width: 15%;
}

.invoice-table th:nth-child(3),
.invoice-table td:nth-child(3) {
    width: 12%;
}

.invoice-table th:nth-child(4),
.invoice-table td:nth-child(4) {
    width: 15%;
}

.invoice-table th:nth-child(5),
.invoice-table td:nth-child(5) {
    width: 10%;
}

.invoice-table th:nth-child(6),
.invoice-table td:nth-child(6) {
    width: 18%;
}

/* 🔥 STEP 1: ALL CELLS GET LEFT + TOP */
.invoice-table th,
.invoice-table td {
    box-shadow:
        inset 1px 0 0 black,   /* LEFT */
        inset 0 1px 0 black;   /* TOP */
}

/* 🔥 STEP 2: LAST COLUMN ADD RIGHT */
.invoice-table tr > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset -1px 0 0 black; /* RIGHT */
}

/* 🔥 STEP 3: LAST ROW ADD BOTTOM */
.invoice-table tbody tr:last-child > * {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset 0 -1px 0 black; /* BOTTOM */
}

/* 🔥 STEP 4: FIX CORNER (last row + last col) */
.invoice-table tbody tr:last-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset -1px 0 0 black,
        inset 0 -1px 0 black;
}

/* 🔥 STEP 5: HEADER BOTTOM LINE FIX
   tbody first row ka top remove kiya tha jisse header bottom thin ho gayi thi
   is liye thead last row pe explicitly bottom add kar rahe hain */
.invoice-table thead tr:last-child > * {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset 0 -1px 0 black; /* BOTTOM */
}

.invoice-table thead tr:last-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset -1px 0 0 black,
        inset 0 -1px 0 black; /* RIGHT + BOTTOM */
}

/* 🔥 STEP 6: tbody FIRST ROW TOP REMOVE
   header bottom + first row top dono hone se double/thick line banti thi */
.invoice-table tbody tr:first-child > * {
    box-shadow:
        inset 1px 0 0 black; /* sirf LEFT, top hataya */
}

.invoice-table tbody tr:first-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset -1px 0 0 black; /* LEFT + RIGHT, top hataya */
}

/* 🔥 STEP 6 EDGE CASE: single data row (first = last) */
.invoice-table tbody tr:first-child:last-child > * {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 -1px 0 black; /* LEFT + BOTTOM */
}

.invoice-table tbody tr:first-child:last-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset -1px 0 0 black,
        inset 0 -1px 0 black; /* LEFT + RIGHT + BOTTOM */
}

/* ✅ PDF SAFE (NO DECIMALS EVER) */
body.is-pdf .invoice-table th,
body.is-pdf .invoice-table td {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black;
}

body.is-pdf .invoice-table tr > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset -1px 0 0 black;
}

body.is-pdf .invoice-table tbody tr:last-child > * {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset 0 -1px 0 black;
}

body.is-pdf .invoice-table tbody tr:last-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset -1px 0 0 black,
        inset 0 -1px 0 black;
}

/* ✅ PDF SAFE: HEADER BOTTOM LINE FIX */
body.is-pdf .invoice-table thead tr:last-child > * {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset 0 -1px 0 black;
}

body.is-pdf .invoice-table thead tr:last-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 1px 0 black,
        inset -1px 0 0 black,
        inset 0 -1px 0 black;
}

/* ✅ PDF SAFE: tbody FIRST ROW TOP REMOVE */
body.is-pdf .invoice-table tbody tr:first-child > * {
    box-shadow:
        inset 1px 0 0 black;
}

body.is-pdf .invoice-table tbody tr:first-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset -1px 0 0 black;
}

/* ✅ PDF SAFE: single data row edge case */
body.is-pdf .invoice-table tbody tr:first-child:last-child > * {
    box-shadow:
        inset 1px 0 0 black,
        inset 0 -1px 0 black;
}

body.is-pdf .invoice-table tbody tr:first-child:last-child > *:last-child {
    box-shadow:
        inset 1px 0 0 black,
        inset -1px 0 0 black,
        inset 0 -1px 0 black;
}
        /* ================= OTHER ================= */

        .invoice-stamp-block {
            transform: scale(1.09);
            transform-origin: center top;
        }

        body.is-pdf .invoice-footer-copy {
            font-size: 14pt !important;
            line-height: 1.05 !important;
        }
    </style>
</head>

<body class="<%= is_pdf ? 'is-pdf ' : '' %> font-bookman text-[12pt]">

    <div class="relative">
        <p class="relative text-center font-calibri-bold text-[16pt] text-[#b4c6e7]">
            PROFORMA INVOICE
        </p>
        <img class="relative bottom-8" src="/finalLogo.png" width="202" height="137">

    </div>


    <div class="w-full  flex justify-end mt-[5px] pr-8">
        <p>DATE - <%= date || '' %></p>
    </div>

    <% for (let i = 0; i < 2; i++) { %>
        <div class="h-[12pt]"></div>
    <% } %>

    <div class="flex flex-col">
        <div class="flex gap-2">
            <p>DL NO.</p>
            <p class="font-bookman-bold"><%= dl_no %></p>
        </div>

        <p>&ensp; ,HRN-115277.</p>

        <div class="flex gap-2">
            <p>GST NO:</p>
            <p class="font-bookman-bold"><%= gst_no %></p>
        </div>
    </div>

    <div class="h-[12pt]"></div>

    <p>TO</p>

    <div class="h-[12pt]"></div>

    <div class="flex flex-col font-bookman-bold">
        <div class="flex gap-2">
            <p>PT.</p>
            <p><%= patient_name %></p>
        </div>

        <div class="flex gap-2">
            <p>IP NO.</p>
            <p><%= ip_no %></p>
        </div>
    </div>

    <div class="h-[12pt]"></div>

    <div>
        <p class="font-bookman-bold"><%= hospital_name %></p>
        <p><%= unit %></p>
        <p style="white-space: pre-line;"><%= address %></p>

        <div class="flex gap-2">
            <p>GST NO:</p>
            <p><%= gst_no %></p>
        </div>
    </div>

    <% for (let i = 0; i < 4; i++) { %>
        <div class="h-[12pt]"></div>
    <% } %>

    <!-- ================= TABLE ================= -->
    <table class="invoice-table text-center text-[11pt] font-bookman leading-none">
        <thead>
            <tr>
                <th>ITEM NAME</th>
                <th>BATCH NO</th>
                <th>EXP</th>
                <th>RATE</th>
                <th>QTY</th>
                <th>AMOUNT</th>
            </tr>
        </thead>

        <tbody>
            <% if (Array.isArray(data) && data.length > 0) { %>
                <% data.forEach(item => { %>
                    <tr>
                        <td><%= item.item_name %></td>
                        <td><%= item.batch_no %></td>
                        <td><%= item.exp %></td>
                        <td><%= item.rate %></td>
                        <td><%= item.quantity %></td>
                        <td><%= item.amount %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6">No items added</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <% for (let i = 0; i < 9-data.length; i++) { %>
        <div class="h-[12pt]"></div>
    <% } %>

    <div class="flex gap-2 font-bookman-bold relative left-[10%]">
        <p>TOTAL AMOUNT -</p>
        <p><%= total_amount %> /-</p>
    </div>

    <% for (let i = 0; i < 3 + (9 - data.length); i++) { %>
        <div class="h-[11pt]"></div>
    <% } %>

    <!-- ================= STAMP ================= -->
    <div class="absolute bottom-1 w-full">
        <div class="flex flex-col items-center text-[12pt] gap-2">

            <div class="relative invoice-stamp-block">
                <img src="/stamp.png" width="721" height="133" class="scale-105">

                <div class="absolute top-[-2px] text-[11pt]">
                    <p class="relative left-[30px]">AUTHORISED SIGNATORY</p>
                    <p class="relative top-[82px] left-[50px]">NEXTGEN BIOTECH</p>
                </div>
            </div>

            <div class="invoice-footer-copy text-center pt-4 text-[#203764] font-calibri-bold text-[13pt]">
                <p>3- DDA Market, Vikrant Enclave, Rajouri Garden New Delhi - 110064</p>
                <p>GSTIN: 07AAKFN5053A1ZK Ph: 011 - 45084455, 9810901789</p>
                <p>Email: nextgenbiotech14@gmail.com, Website: www.ngbindia.in</p>
            </div>

        </div>
    </div>

</body>
</html>