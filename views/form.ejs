                address: "MURTHAL ROAD, SONIPAT, HARYANA-131001",
                gst: "06AACCN3314M2ZI",
                location: "Sonipat"
            },
            "PARK_HOSPITAL_DELHI": {
                displayName: "PARK HOSPITAL",
                unit: "(A UNIT OF PARK MEDIWORLD PVT.LTD)",
                address: "12, MEERA ENCLAVE CHOWKHANDI NEAR\nKESHOPUR BUS DEPOT, WEST DELHI -110018",
                gst: "07AAFCP8305H1ZE",
                location: "Delhi"
            },
            "PARK_HOSPITAL_GT_ROAD": {
                displayName: "PARK HOSPITAL (GT ROAD)",
                unit: "(A UNIT OF DMR HOSPITAL PVT.LTD)",
                address: "CHD CITY, SECTOR-45, GT ROAD\nKARNAL, HARYANA 06-HARYANA 132116",
                gst: "",
                location: "Karnal"
            },
            "PARK_HOSPITAL_PALAM_VIHAR": {
                displayName: "PARK HOSPITAL",
                unit: "(A UNIT OF UMKAL HEALTHCARE PVT.LTD)",
                address: "H-BLOCK, PALAM VIHAR, GURGRAM - 122017",
                gst: "06AAACU7727R1ZN",
                location: "Gurugram"
            },
            "PARK_HOSPITAL_PANIPAT": {
                displayName: "PARK HOSPITAL",
                unit: "(A UNIT OF PARK MEDICITY INDIA PVT.LTD)",
                address: "NH-1, SEWAH, PANIPAT, HARYANA",
                gst: "06AAFCP9325H1ZA",
                location: "Panipat"
            },
            "PARK_HOSPITAL_PATIALA": {
                displayName: "PARK HOSPITAL (PATIALA)",
                unit: "(A UNIT OF PARK MEDICITY (WORLD) PVT. LTD)",
                address: "URBAN ESTATE, PHASE- 1,\nNEW BUS STAND, PATIALA, PUNJAB 03-PUNJAB 147002",
                gst: "03AAJCP0176C1ZV",
                location: "Patiala"
            },
            "PARK_HOSPITAL_SECTOR_47": {
                displayName: "PARK HOSPITAL",
                unit: "(A UNIT OF PARK MEDICENTERS & INSTITUTIONS P.L)",
                address: "Q-BLOCK, SOUTH CITY, SOHNA ROAD\nSECTOR-47, GURUGRAM-122001",
                gst: "06AAFCP4102Q1ZA",
                location: "Gurugram"
            },
            "SIGNATURE_HOSPITAL": {
                displayName: "THE SIGNATURE HOSPITAL",
                unit: "(A UNIT OF PARK MEDICITY(NORTH) PVT.LTD)",
                address: "SECTOR-37D, BPTP DWARKA EXPRESSWAY\nGURUGRAM -122001",
                gst: "06AAICP8687M1ZH",
                location: "Gurugram"
            },
            "Other": {
                displayName: "",
                unit: "",
                address: "",
                gst: "",
                location: ""
            }
        };

        const invoiceForm = document.getElementById('invoice_form');
        const hospitalSelect = document.getElementById('hospital_select');
        const customHospitalGroup = document.getElementById('custom_hospital_group');
        const customHospitalInput = document.getElementById('custom_hospital_name');
        const unitInput = document.getElementById('unit');
        const addressInput = document.getElementById('address');
        const gstInput = document.getElementById('gst_no');
        const locationInput = document.getElementById('location');
        const hospitalDisplayInput = document.getElementById('hospital_display');
        const itemsTbody = document.getElementById('items_tbody');
        const submitButton = invoiceForm.querySelector('button[type="submit"]');
        const submitButtonDefaultHtml = submitButton.innerHTML;
        const initialItemRowMarkup = itemsTbody.innerHTML;

        let isGeneratingPdf = false;

        function normalizeAddressLines(value) {
            return String(value || '')
                .replace(/\\n/g, '\n')
                .replace(/\/n/g, '\n');
        }

        hospitalSelect.addEventListener('change', (e) => {
            const selected = e.target.value;
            const isOther = selected === 'Other';
            
            // Toggle Readonly based on 'Other' selection
            unitInput.readOnly = !isOther;
            addressInput.readOnly = !isOther;
            gstInput.readOnly = !isOther;
            locationInput.readOnly = !isOther;

            // Toggle custom name group
            customHospitalGroup.style.display = isOther ? 'flex' : 'none';
            if (isOther) {
                customHospitalInput.required = true;
            } else {
                customHospitalInput.required = false;
                customHospitalInput.value = '';
            }

            if (hospitalData[selected]) {
                hospitalDisplayInput.value = hospitalData[selected].displayName || '';
                unitInput.value = hospitalData[selected].unit;
                addressInput.value = normalizeAddressLines(hospitalData[selected].address);
                gstInput.value = hospitalData[selected].gst;
                locationInput.value = hospitalData[selected].location;
            } else {
                hospitalDisplayInput.value = '';
                unitInput.value = '';
                addressInput.value = '';
                gstInput.value = '';
                locationInput.value = '';
            }

            if (isOther) {
                unitInput.placeholder = "Enter Unit details";
                addressInput.placeholder = "Enter full Address";
                gstInput.placeholder = "Enter GST Number";
                locationInput.placeholder = "Enter Location/City";
            } else {
                unitInput.placeholder = "";
                addressInput.placeholder = "";
                gstInput.placeholder = "";
                locationInput.placeholder = "";
            }
        });

        customHospitalInput.addEventListener('input', () => {
            if (hospitalSelect.value === 'Other') {
                hospitalDisplayInput.value = customHospitalInput.value.trim();
            }
        });

        function parseFilenameFromDisposition(disposition) {
            if (!disposition) return 'invoice.pdf';

            const utf8Match = disposition.match(/filename\*=UTF-8''([^;]+)/i);
            if (utf8Match && utf8Match[1]) {
                try {
                    return decodeURIComponent(utf8Match[1]);
                } catch (error) {
                    console.warn('Unable to decode UTF-8 filename:', error);
                }
            }

            const asciiMatch = disposition.match(/filename="?([^";]+)"?/i);
            if (asciiMatch && asciiMatch[1]) {
                return asciiMatch[1];
            }

            return 'invoice.pdf';
        }

        function triggerDownload(blob, fileName) {
            const blobUrl = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = blobUrl;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            link.remove();
            setTimeout(() => URL.revokeObjectURL(blobUrl), 5000);
        }

        function setDefaultInvoiceDate() {
            document.getElementById('date').valueAsDate = new Date();
        }

        function resetInvoiceFormAfterDownload() {
            invoiceForm.reset();
            itemsTbody.innerHTML = initialItemRowMarkup;
            itemIndex = 1;

            const firstRow = itemsTbody.querySelector('.item-row');
            if (firstRow) attachListeners(firstRow);

            hospitalSelect.dispatchEvent(new Event('change'));
            hospitalDisplayInput.value = '';
            calculateTotal();
            setDefaultInvoiceDate();
        }

        invoiceForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (isGeneratingPdf) return;
            if (!invoiceForm.reportValidity()) return;

            isGeneratingPdf = true;
            submitButton.disabled = true;
            submitButton.textContent = 'Generating...';

            try {
                const formData = new FormData(invoiceForm);
                const encodedFormData = new URLSearchParams();
                formData.forEach((value, key) => {
                    encodedFormData.append(key, String(value));
                });

                const response = await fetch(invoiceForm.action, {
                    method: 'POST',
                    body: encodedFormData,
                });

                if (!response.ok) {
                    throw new Error(`Failed to generate PDF (status: ${response.status})`);
                }

                const contentDisposition = response.headers.get('content-disposition');
                const fileName = parseFilenameFromDisposition(contentDisposition);
                const pdfBlob = await response.blob();

                triggerDownload(pdfBlob, fileName);
                resetInvoiceFormAfterDownload();
            } catch (error) {
                console.error('PDF download error:', error);
                alert('PDF generate nahi ho paaya. Please dobara try karein.');
            } finally {
                submitButton.disabled = false;
                submitButton.innerHTML = submitButtonDefaultHtml;
                isGeneratingPdf = false;
            }
        });

        let itemIndex = 1;
        function addItem() {
            const row = document.createElement('tr');
            row.classList.add('item-row');
            row.innerHTML = `
                <td><input type="text" name="data[${itemIndex}][item_name]" required></td>
                <td><input type="text" name="data[${itemIndex}][batch_no]" required></td>
                <td><input type="month" name="data[${itemIndex}][exp]" required></td>
                <td><input type="number" step="0.01" min="0" name="data[${itemIndex}][rate]" class="rate-input" required></td>
                <td><input type="number" min="1" name="data[${itemIndex}][quantity]" class="qty-input" required></td>
                <td><input type="text" inputmode="decimal" name="data[${itemIndex}][amount]" class="amount-input" readonly></td>
                <td><button type="button" class="btn btn-danger" onclick="removeItem(this)">&times;</button></td>
            `;
            itemsTbody.appendChild(row);
            itemIndex++;
            attachListeners(row);
        }

        function removeItem(btn) {
            btn.closest('tr').remove();
            calculateTotal();
        }

        const NUMERIC_TEXT_REGEX = /^[+-]?(?:\d+(?:\.\d*)?|\.\d+)$/;

        function uppercaseText(value) {
            if (value === null || value === undefined) return '';
            return String(value).toUpperCase();
        }

        function isNumericText(value) {
            return NUMERIC_TEXT_REGEX.test(String(value || '').trim());
        }

        function getDecimalsFromString(value) {
            const text = String(value || '').trim();
            if (!text || !isNumericText(text)) return 0;
            const dotIndex = text.indexOf('.');
            if (dotIndex === -1) return 0;
            return Math.max(0, text.length - dotIndex - 1);
        }

        function trimNumericString(value) {
            if (!value.includes('.')) return value;
            return value.replace(/(\.\d*?[1-9])0+$/, '$1').replace(/\.0+$/, '');
        }

        function formatNumber(value) {
            if (value === null || value === undefined) return '0';

            if (typeof value === 'string') {
                const text = value.trim();
                if (!text || !isNumericText(text)) return '0';

                const numeric = Number(text);
                if (!Number.isFinite(numeric)) return '0';

                const unsignedText = text.replace(/^[+-]/, '');
                const sign = numeric < 0 ? '-' : '';

                if (!unsignedText.includes('.')) {
                    return `${sign}${String(Math.abs(numeric))}`;
                }

                const [integerRaw = '0', fractionRaw = ''] = unsignedText.split('.');
                const integerPart = String(Number(integerRaw || '0'));

                if (!fractionRaw || /^0+$/.test(fractionRaw)) {
                    return `${sign}${integerPart}`;
                }

                return `${sign}${integerPart}.${fractionRaw}`;
            }

            const numeric = Number(value);
            if (!Number.isFinite(numeric) || Object.is(numeric, -0) || numeric === 0) return '0';

            const asText = String(numeric);
            if (!/[eE]/.test(asText)) {
                return trimNumericString(asText);
            }

            return trimNumericString(numeric.toFixed(12));
        }

        function calculateAndFormatTotal(rateValue, qtyValue) {
            const rateText = String(rateValue || '').trim();
            const qtyText = String(qtyValue || '').trim();

            const rate = Number(rateText);
            const qty = Number(qtyText);

            if (!Number.isFinite(rate) || !Number.isFinite(qty)) {
                return '0';
            }

            const total = rate * qty;
            const scale = Math.min(10, getDecimalsFromString(rateText) + getDecimalsFromString(qtyText));

            if (scale <= 0) {
                return formatNumber(total);
            }

            return formatNumber(total.toFixed(scale));
        }

        function calculateAmount(row) {
            const rateInput = row.querySelector('.rate-input');
            const qtyInput = row.querySelector('.qty-input');
            const amountInput = row.querySelector('.amount-input');

            const rateRaw = rateInput.value || '';
            const qtyRaw = qtyInput.value || '';
            const formattedAmount = calculateAndFormatTotal(rateRaw, qtyRaw);
            amountInput.value = formattedAmount;
            amountInput.dataset.decimals = String(getDecimalsFromString(formattedAmount));
            calculateTotal();
        }

        function calculateTotal() {
            let total = 0;
            let maxDecimals = 0;
            document.querySelectorAll('.amount-input').forEach(input => {
                total += parseFloat(input.value) || 0;
                const decimals = Number.parseInt(input.dataset.decimals || getDecimalsFromString(input.value), 10);
                if (decimals > maxDecimals) maxDecimals = decimals;
            });

            const formattedTotal = maxDecimals > 0
                ? formatNumber(total.toFixed(Math.min(maxDecimals, 10)))
                : formatNumber(total);

            document.getElementById('total_amount_display').innerText = formattedTotal;
            document.getElementById('total_amount_hidden').value = formattedTotal;
        }

        function attachListeners(row) {
            row.querySelector('.rate-input').addEventListener('input', () => calculateAmount(row));
            row.querySelector('.qty-input').addEventListener('input', () => calculateAmount(row));
        }

        // Initial listener for the first row
        attachListeners(document.querySelector('.item-row'));

        document.addEventListener('input', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLInputElement) && !(target instanceof HTMLTextAreaElement)) {
                return;
            }

            const shouldUppercase = (target.matches('input[type="text"]') || target.matches('textarea'))
                && !target.classList.contains('amount-input');

            if (!shouldUppercase) return;

            const cursorStart = target.selectionStart;
            const cursorEnd = target.selectionEnd;
            target.value = uppercaseText(target.value);

            if (typeof cursorStart === 'number' && typeof cursorEnd === 'number') {
                target.setSelectionRange(cursorStart, cursorEnd);
            }
        });
        
        // Default today's date
        setDefaultInvoiceDate();
    </script>
</body>
</html>

