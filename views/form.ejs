<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice Generator</title>
    <script>
        (function installMgtClearMarksShim(root) {
            var clearMarks = function clearMarks(markName) {
                if (root.performance && typeof root.performance.clearMarks === 'function') {
                    root.performance.clearMarks(markName);
                }
            };

            var mgtRef = (root.mgt && typeof root.mgt === 'object') ? root.mgt : {};
            mgtRef.clearMarks = clearMarks;

            try {
                Object.defineProperty(root, 'mgt', {
                    configurable: true,
                    get: function getMgt() {
                        return mgtRef;
                    },
                    set: function setMgt(value) {
                        mgtRef = (value && typeof value === 'object') ? value : {};
                        mgtRef.clearMarks = clearMarks;
                    }
                });
            } catch (e) {
                root.mgt = mgtRef;
            }
        })(window);
    </script>
    <link rel="stylesheet" href="/form.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <header>
            <h1>NextGen Invoice</h1>
            <p class="subtitle">Quickly generate professional proforma invoices</p>
        </header>
        
        <form id="invoice_form" action="/generate" method="POST">
            <div class="section">
                <h2 class="section-title">General Details</h2>
                <div class="grid">
                    <div class="form-group">
                        <label for="date">Invoice Date</label>
                        <input type="date" id="date" name="date" required>
                    </div>
                    <div class="form-group">
                        <label for="patient_name">Patient Name</label>
                        <input type="text" id="patient_name" name="patient_name" placeholder="Enter patient name" required>
                    </div>
                    <div class="form-group">
                        <label for="ip_no">IP Number</label>
                        <input type="text" id="ip_no" name="ip_no" placeholder="e.g. 102345" required>
                    </div>
                </div>
            </div>

            <div class="section">
                <h2 class="section-title">Hospital Details</h2>
                <div class="grid">
                    <div class="form-group">
                        <label for="hospital_select">Select Hospital</label>
                        <select id="hospital_select" name="hospital_name" required>
                            <option value="">-- Choose Hospital --</option>
                            <option value="AMAR_MEDICAL">AMAR MEDICAL AND RESEARCH CENTRE</option>
                            <option value="GRECIAN_HOSPITAL">GRECIAN HOSPITAL</option>
                            <option value="HEALING_TOUCH_HOSPITAL">HEALING TOUCH HOSPITAL</option>
                            <option value="KRISHNA_SUPER_SPECILITY_HOSPITAL">KRISHNA SUPER SPECILITY HOSPITAL</option>
                            <option value="NIDDAN_HOSPITAL">NIDDAN HOSPITAL</option>
                            <option value="PARK_HOSPITAL_DELHI">PARK HOSPITAL - DELHI</option>
                            <option value="PARK_HOSPITAL_GT_ROAD">PARK HOSPITAL (GT ROAD)</option>
                            <option value="PARK_HOSPITAL_PALAM_VIHAR">PARK HOSPITAL - PALAM VIHAR</option>
                            <option value="PARK_HOSPITAL_PANIPAT">PARK HOSPITAL - PANIPAT</option>
                            <option value="PARK_HOSPITAL_PATIALA">PARK HOSPITAL (PATIALA)</option>
                            <option value="PARK_HOSPITAL_SECTOR_47">PARK HOSPITAL - SECTOR-47</option>
                            <option value="SIGNATURE_HOSPITAL">THE SIGNATURE HOSPITAL</option>
                            <option value="Other">Other</option>
                        </select>
                        <input type="hidden" id="hospital_display" name="hospital_display" value="">
                    </div>
                    <div class="form-group" id="custom_hospital_group" style="display: none;">
                        <label for="custom_hospital_name">Custom Hospital Name</label>
                        <input type="text" id="custom_hospital_name" name="custom_hospital_name" placeholder="Enter hospital name">
                    </div>
                    <div class="form-group">
                        <label for="unit">Parent Unit</label>
                        <input type="text" id="unit" name="unit" readonly placeholder="Auto-filled from selection">
                    </div>
                    <div class="form-group">
                        <label for="gst_no">GST Number</label>
                        <input type="text" id="gst_no" name="gst_no" readonly placeholder="Auto-filled from selection">
                    </div>
                    <div class="form-group">
                        <label for="location">Location</label>
                        <input type="text" id="location" name="location" readonly placeholder="Auto-filled from selection">
                    </div>
                </div>
                <div class="form-group" style="margin-top: 1.5rem;">
                    <label for="address">Full Address</label>
                    <textarea id="address" name="address" rows="2" readonly placeholder="Auto-filled from selection"></textarea>
                </div>
            </div>

            <div class="section">
                <h2 class="section-title">Medicine & Item List</h2>
                <div class="items-table-container">
                    <div class="table-wrapper">
                        <table id="items_table">
                            <thead>
                                <tr>
                                    <th>Medicine Name</th>
                                    <th>Batch No.</th>
                                    <th>Expiry</th>
                                    <th>Rate (&#8377;)</th>
                                    <th>Qty</th>
                                    <th>Amount (&#8377;)</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="items_tbody">
                                <tr class="item-row">
                                    <td><input type="text" name="data[0][item_name]" required placeholder="Medicine Name"></td>
                                    <td><input type="text" name="data[0][batch_no]" required placeholder="B123..."></td>
                                    <td><input type="month" name="data[0][exp]" required></td>
                                    <td><input type="number" step="0.01" min="0" name="data[0][rate]" class="rate-input" required placeholder="0.00"></td>
                                    <td><input type="number" min="1" name="data[0][quantity]" class="qty-input" required placeholder="0"></td>
                                    <td><input type="text" inputmode="decimal" name="data[0][amount]" class="amount-input" readonly value="0"></td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <button type="button" class="btn btn-secondary" onclick="addItem()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Add New Item
                    </button>
                    
                    <div class="total-section">
                        <div class="total-label">Grand Total</div>
                        <input type="hidden" name="total_amount" id="total_amount_hidden" value="0.00">
                        <div class="total-amount">&#8377;<span id="total_amount_display">0.00</span></div>
                    </div>
                </div>
            </div>

            <div class="submit-container">
                <button type="submit" class="btn btn-primary submit-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9l-7-7z" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 2v7h7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Generate Professional Invoice
                </button>
            </div>
        </form>
    </div>

    <script>
        const hospitalData = {
