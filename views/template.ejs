    <% const formatExpTitleCase = (value) => {
      const text = (value || '').toString().trim();
      if (!text) return '';
      const [monthPart, yearPart] = text.split('-');
      if (!monthPart) return text;
      const normalizedMonth = monthPart.charAt(0).toUpperCase() + monthPart.slice(1).toLowerCase();
      return yearPart ? `${normalizedMonth}-${yearPart}` : normalizedMonth;
    }; %>

