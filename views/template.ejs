<% const isPdf = (typeof is_pdf !== 'undefined') && is_pdf; %>
<% const escapeHtml = (value = '') => value
  .toString()
  .replace(/&/g, '&amp;')
  .replace(/</g, '&lt;')
  .replace(/>/g, '&gt;')
  .replace(/"/g, '&quot;')
  .replace(/'/g, '&#39;'); %>
<% const renderMultiline = (value = '') => escapeHtml(value).trim().replace(/\r?\n/g, '<br>'); %>
<% const semiBoldText = (value = '') => {
  const text = escapeHtml(value || '');
  if (!text) return '';
  return `<span style="font-family:'Bookman Old Style',serif;font-weight:var(--semi-bold-weight, 550);color:var(--semi-bold-color, #000);opacity:0.88;font-synthesis:weight;">${text}</span>`;
}; %>
<% const strictBookmanText = (value = '') => {
  const text = escapeHtml(value || '');
  if (!text) return '';
  return `<span style="font-family:'Bookman Old Style',serif;font-weight:400;color:#000;">${text}</span>`;
}; %>
<% const formatDateDMY = (value = '') => {
  const text = (value || '').toString().trim();
  if (!text) return '';
  // If already dd-mm-yyyy, keep as-is.
  if (/^\d{2}-\d{2}-\d{4}$/.test(text)) return text;
  // Handle yyyy-mm-dd or yyyy/mm/dd
  const m = text.match(/^(\d{4})[-/](\d{1,2})[-/](\d{1,2})$/);
  if (m) {
    const year = m[1];
    const month = m[2].padStart(2, '0');
    const day = m[3].padStart(2, '0');
    return `${day}-${month}-${year}`;
  }
  return text;
}; %>
