{
  "name": "app",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon --watch server.js --watch views --ext js,ejs server.js\" \"npm run tw:watch\"",
    "build": "npx puppeteer browsers install chrome",
    "tw:build": "tailwindcss -i ./public/tailwind.css -o ./public/tw.css --minify",
    "tw:watch": "tailwindcss -i ./public/tailwind.css -o ./public/tw.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
